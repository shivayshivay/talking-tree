# ── Talking Trees Environment Variables ──
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/talking_trees
MONGO_URI=mongodb://localhost:27017

# Flask secret (any random string)
SECRET_KEY=talking-trees-secret-2024

# Optional: Anthropic API key (for server-side leaf AI)
ANTHROPIC_API_KEY=your_anthropic_key_here
